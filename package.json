{
  "name": "neuralgateway",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared/db",
    "shared/memory",
    "shared/types",
    "services/gateway",
    "services/queue",
    "services/ingestion",
    "services/embedding",
    "services/retrieval",
    "services/generation"
  ],
  "scripts": {
    "migrate": "ts-node shared/db/migrate.ts",
    "dev:gateway": "npm run dev --workspace=services/gateway",
    "dev:queue": "npm run dev --workspace=services/queue",
    "dev:ingestion": "npm run dev --workspace=services/ingestion",
    "dev:embedding": "npm run dev --workspace=services/embedding",
    "dev:retrieval": "npm run dev --workspace=services/retrieval",
    "dev:generation": "npm run dev --workspace=services/generation",
    "build": "npm run build --workspaces --if-present"
  },
  "devDependencies": {
    "@types/node": "^20.11.0",
    "@types/pg": "^8.20.0",
    "dotenv": "^16.4.1",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.3.3"
  }
}
